# WebSocket URL - Obtenha após deploy do backend
VITE_WEBSOCKET_URL=wss://seu-id.execute-api.us-east-1.amazonaws.com/prod

# Cognito User Pool - Obtenha após deploy do backend
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Região AWS
VITE_REGION=us-east-1

# API URLs - Obtenha após deploy do backend
VITE_API_URL=https://your-lambda-function-url.lambda-url.us-east-1.on.aws
VITE_CHIME_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# TURN Credentials API URL
VITE_TURN_API_URL=https://your-turn-lambda-url.lambda-url.us-east-1.on.aws

# Backoffice URL
VITE_BACKOFFICE_URL=https://your-backoffice-domain.com
